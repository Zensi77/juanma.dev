---
const estudios = [
  {
    fecha: 'Septiembre 2023 - Junio 2025',
    titulo: 'Técnico Superior en Desarrollo de Aplicaciones Web',
    descripcion:
      'Formación en tecnologías de desarrollo web, incluyendo HTML, CSS, JavaScript, Angular, Node.js, Express y MongoDB.',
  },
  {
    fecha: '2018',
    titulo: 'Grado en Ingeniería Química',
    descripcion:
      'Realicé la transición de la Ingeniería Química a la Programación Web, aprovechando mi formación en pensamiento analítico y resolución de problemas para mejorar el desarrollo de aplicaciones web.',
  },
  {
    fecha: 'Diciembre 2024',
    titulo: 'Angular de 0 a Experto - DevTalles',
    descripcion:
      'Certificación adquirida en Angular y TypeScript, aprendiendo a desarrollar aplicaciones web robustas y escalables.',
    certificado: 'https://cursos.devtalles.com/certificates/cvmii0lmez',
  },
  {
    fecha: 'Noviembre 2024',
    titulo: 'Node.js - DevTalles',
    descripcion:
      'Certificación en Node.js y TypeScript, con énfasis en el desarrollo backend para aplicaciones web.',
    certificado: 'https://cursos.devtalles.com/certificates/cvmii0lmez',
  },
];

const experienciaLaboral = [
  {
    fecha: 'Marzo 2023 - Septiembre 2023',
    puesto: 'Food Service Worker - Burger King',
    descripcion:
      'Trabajo en equipo: Colaboración constante con compañeros para garantizar la eficiencia en el servicio. Manejo de la presión: Capacidad para mantener la calidad y rapidez del servicio en un entorno de alta demanda, algo esencial en el desarrollo cuando se manejan proyectos complejos o plazos ajustados.',
  },
  {
    fecha: 'Enero 2022 - Diciembre 2022',
    puesto: 'Operario de Envasado - AVINATUR PRODUCCIONES AVICOLAS SL',
    descripcion:
      'Organización y Gestión de Proyectos: Coordinación de procesos para garantizar el flujo constante de trabajo y cumplimiento de los tiempos establecidos. Trabajo en equipo: Coordinación con diferentes equipos para asegurar el éxito de la producción en un entorno de trabajo colaborativo.',
  },
  {
    fecha: 'Julio 2018 - Febrero 2020',
    puesto: 'Profesor de Clases Particulares matematicas, fisica y quimica',
    descripcion:
      'Comunicación Efectiva: Mejora de la capacidad de explicar conceptos complejos de manera clara y sencilla, una habilidad valiosa en el desarrollo cuando se trabaja en equipo o se presenta código. Aptitudes de Organización: Planificación y gestión del tiempo para asegurar que las lecciones fueran efectivas y los estudiantes pudieran aprender de manera óptima.',
  },
];
---

<section
  id='sobre-mi'
  class='flex flex-col xl:flex-row gap-12 items-start justify-cente mt-12'
>
  <div class='bg-gray-400 rounded-3xl shadow-2xl p-12 bg-cristal w-full'>
    <h2
      class='text-3xl font-bold mb-12 text-gray-900 dark:text-white text-center'
    >
      Educación
    </h2>
    <ol class='relative border-s border-gray-200 dark:border-gray-700'>
      {
        estudios.map((estudio) => (
          <li class='mb-10 ms-4'>
            <div class='absolute w-3 h-3 bg-gray-200 rounded-full mt-1.5 -start-1.5 border border-white dark:border-gray-900 dark:bg-gray-700' />
            <time class='mb-1 text-sm font-normal leading-none text-gray-400 dark:text-gray-800'>
              {estudio.fecha}
            </time>
            <h3 class='text-lg font-semibold text-gray-900 dark:text-white'>
              {estudio.titulo}
            </h3>
            <p class='mb-4 text-base font-normal'>
              {estudio.descripcion}
              {estudio.certificado && (
                <a href={estudio.certificado}>
                  <span class='text-blue-500 dark:text-blue-500 hover:text-blue-600 transition-colors'>
                    Ver certificado
                  </span>
                </a>
              )}
            </p>
          </li>
        ))
      }
    </ol>
  </div>

  <div class='bg-gray-400 rounded-3xl shadow-2xl p-12 w-full bg-cristal'>
    <h2
      class='text-3xl font-bold mb-12 text-gray-900 dark:text-white text-center'
    >
      Experiencia Laboral
    </h2>
    <ol class='relative border-s border-gray-200 dark:border-gray-700'>
      {
        experienciaLaboral.map((experiencia) => (
          <li class='mb-10 ms-6'>
            <span class='absolute flex items-center justify-center w-6 h-6 bg-blue-100 rounded-full -start-3 ring-8 ring-white dark:ring-gray-900 dark:bg-blue-900'>
              <svg
                class='w-2.5 h-2.5 text-blue-800 dark:text-blue-300'
                aria-hidden='true'
                xmlns='http://www.w3.org/2000/svg'
                fill='currentColor'
                viewBox='0 0 20 20'
              >
                <path d='M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z' />
              </svg>
            </span>
            <h3 class='flex items-center mb-1 text-lg font-semibold text-gray-900 dark:text-white'>
              {experiencia.puesto}
            </h3>
            <time class='block mb-2 text-sm font-normal leading-none text-gray-400 dark:text-gray-800'>
              {experiencia.fecha}
            </time>
            <p class='mb-4 text-base font-normal'>{experiencia.descripcion}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
