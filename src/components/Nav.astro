<script>
  window.addEventListener('hashchange', updateActiveLink);
  document.addEventListener('DOMContentLoaded', updateActiveLink);

  function updateActiveLink() {
    const currentHash = window.location.hash;
    const links = document.querySelectorAll('.nav-link'); // Selecciona los enlaces

    links.forEach((link) => {
      if (link.getAttribute('href') === currentHash) {
        link.classList.add('bg-gray-800', 'rounded-md', 'shadow-md'); // Resalta el enlace actual
        const targetElement = document.querySelector(currentHash);
        if (targetElement) {
          targetElement.scrollIntoView({ behavior: 'smooth' });
        }
      } else {
        link.classList.remove('bg-gray-800'); // Elimina el resaltado de otros enlaces
      }
    });
  }
</script>

